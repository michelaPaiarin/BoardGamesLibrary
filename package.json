{
  "name": "boardgameslibrary",
  "version": "1.0.0",
  "type": "module",
  "private": true, 
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:backend": "npm start --workspace=backend",
    "dev:frontend": "npm run watch:css --workspace=frontend",
    "start": "concurrently -n \"SERVER,TAILWIND\" -c \"magenta.bold,blue.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "init-db": "node backend/DB/initDB.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michelaPaiarin/BoardGamesLibrary.git"
  },
  "keywords": [],
